dotnet_style_parentheses_in_other_operators=never_if_unnecessary:silent

# CodeStructure.Analyzers diagnostics - uses analyzer defaults
# To customize, uncomment and adjust:
# dotnet_diagnostic.STR0001.severity=warning  # No continue statements (default: error)
# dotnet_diagnostic.STR0002.severity=warning  # Multiple returns (default: error)
# dotnet_diagnostic.STR0005.severity=warning  # Return in nested block (default: error)
# dotnet_diagnostic.STY0002.severity=warning  # Null-forgiving operator (default: error)
# dotnet_diagnostic.STY0003.severity=warning  # Avoid dynamic (default: error)

